# ===========================================
# BitByBit Arena — Environment Variables
# ===========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local

# Database (Neon PostgreSQL) — REQUIRED
# Use the appropriate Neon branch for each environment:
#   - Production: main branch
#   - Preview:    dev branch
#   - CI tests:   test branch
DATABASE_URL=postgresql://user@localhost:5433/bitbybit_arena

# Auth — JWT signing secret
# REQUIRED in production (lib/auth.ts throws at module load if unset).
# In dev/test a deterministic fallback string is used so the test suite and
# `npm run dev` work without any env setup.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=change-this-to-a-random-string

# Public — App base URL — REQUIRED
# Used for metadataBase, canonical URLs, sitemap, and robots.txt — must be set
# or the app will throw at boot.
# Production: https://arena.bitbybit.com.ar
# Preview:    auto-set by Vercel
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public — Lightning address for zap donations on the landing page — REQUIRED for zaps
# The landing ZapModal + the seeded mock users' `lightning_address`
# both read this env var, so it's the single place to point
# donations and seed-demo payouts at a Lightning wallet you control.
# If unset, the landing ZapModal surfaces an "errorNoAddress" state
# and the seed demo payout loop 400s on the first winner.
NEXT_PUBLIC_ZAP_LIGHTNING_ADDRESS=your-lud16@example.com

# NWC — Nostr Wallet Connect URL — OPTIONAL
# Used by /api/zap/status to check whether a BOLT11 invoice has settled.
# If unset, the endpoint returns { paid: false } and the landing ZapModal /
# challenge reward modal rely on WebLN feedback only.
# Get this from your wallet app (e.g. Alby, Primal, Mutiny).
# Format: nostr+walletconnect://...
NWC_CONNECTION_URL=

# Public — Blossom server for content-addressed image uploads — OPTIONAL
# Used by lib/nostr/blossom.ts for completion photos and badge images.
# Falls back to https://blossom.primal.net when unset.
NEXT_PUBLIC_BLOSSOM_SERVER=

# Seed owner pubkey — REQUIRED for `npm run db:seed`
# Nostr pubkey that owns the seeded demo challenges, including the
# "Demo: Tiered Prize Payout" challenge a judge uses to exercise the
# creator payout flow without walking through join + proof + approve
# first. Log in with this pubkey to see "Distribute rewards" on that
# challenge. Accepts either bech32 `npub1…` or raw 64-character hex.
# The seeder refuses to run when unset.
SEED_OWNER_PUBKEY=
