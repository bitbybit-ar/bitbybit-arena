# ===========================================
# BitByBit Arena — Environment Variables
# ===========================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local

# Database (Neon PostgreSQL)
# Use the appropriate Neon branch for each environment:
#   - Production: main branch
#   - Preview:    dev branch
#   - CI tests:   test branch
DATABASE_URL=postgresql://user@localhost:5433/bitbybit_arena

# Auth — JWT signing secret
# Must be different per environment
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=change-this-to-a-random-string

# Public — App base URL
# Production: https://arena.bitbybit.com.ar
# Preview: auto-set by Vercel
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public — Lightning address for zap donations
NEXT_PUBLIC_ZAP_LIGHTNING_ADDRESS=devs@bitbybit.com.ar
